<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <!-- ===================== TOOLBAR TABS ===================== -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabEditorTools"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            app:tabIndicatorColor="#7FD8A6"
            app:tabSelectedTextColor="#7FD8A6"
            app:tabTextColor="#666"
            app:tabMode="fixed"
            app:tabIndicatorHeight="2dp"
            app:tabTextAppearance="@style/TextAppearance.MaterialComponents.Caption"
            android:background="@android:color/transparent" />

        <!-- ===================== TOOLS: UMUM ===================== -->
        <LinearLayout
            android:id="@+id/layoutToolsGeneral"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_scene_card"
            android:padding="8dp"
            android:layout_marginTop="4dp">

            <LinearLayout
                android:id="@+id/toolBgPicker"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageButton
                    android:id="@+id/btnBgPicker"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_slideshow"
                    android:padding="8dp"
                    app:tint="#7FD8A6"
                    android:contentDescription="Ganti background" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BG"
                    android:textColor="#AAA"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toolAddLayer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageButton
                    android:id="@+id/btnAddImage"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:padding="8dp"
                    app:tint="#7FD8A6"
                    android:contentDescription="Tambah layer gambar/video" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Media"
                    android:textColor="#AAA"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toolAddText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageButton
                    android:id="@+id/btnAddText"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_edit"
                    android:padding="8dp"
                    app:tint="#7FD8A6"
                    android:contentDescription="Tambah layer teks" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teks"
                    android:textColor="#AAA"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toolAddVoiceAnim"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageButton
                    android:id="@+id/btnAddVoiceAnim"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/camera_retro"
                    android:padding="8dp"
                    app:tint="#7FD8A6"
                    android:contentDescription="Tambah Voice Animation" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voice"
                    android:textColor="#AAA"
                    android:textSize="9sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ===================== TOOLS: TIKTOK ===================== -->
        <LinearLayout
            android:id="@+id/layoutToolsTikTok"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_scene_card"
            android:padding="8dp"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/toolAddTikTokChat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageButton
                    android:id="@+id/btnAddTikTokChat"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_send"
                    android:padding="8dp"
                    app:tint="#7FD8A6"
                    android:contentDescription="Tambah TikTok Chat" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chat"
                    android:textColor="#AAA"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toolAddTikTokGift"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageButton
                    android:id="@+id/btnAddTikTokGift"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/btn_star_big_on"
                    android:padding="8dp"
                    app:tint="#7FD8A6"
                    android:contentDescription="Tambah TikTok Gift" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gift"
                    android:textColor="#AAA"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toolAddTikTokJoin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageButton
                    android:id="@+id/btnAddTikTokJoin"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_add"
                    android:padding="8dp"
                    app:tint="#7FD8A6"
                    android:contentDescription="Tambah TikTok Join" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Join"
                    android:textColor="#AAA"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toolAddMusicCurrent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageButton
                    android:id="@+id/btnAddMusicCurrent"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_media_play"
                    android:padding="8dp"
                    app:tint="#7FD8A6"
                    android:contentDescription="Tambah Music Current" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Music"
                    android:textColor="#AAA"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toolAddMusicQueue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageButton
                    android:id="@+id/btnAddMusicQueue"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_recent_history"
                    android:padding="8dp"
                    app:tint="#7FD8A6"
                    android:contentDescription="Tambah Music Queue" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Queue"
                    android:textColor="#AAA"
                    android:textSize="9sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ===================== LAYER STRIP: klik utk pilih, X utk hapus ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LAYERS"
                android:textColor="#7FD8A6"
                android:textStyle="bold"
                android:textSize="11sp" />
            <TextView
                android:id="@+id/tvLayerCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="0 layer"
                android:textColor="#666"
                android:textSize="10sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLayerStrip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="64dp"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:orientation="horizontal" />

        <TextView
            android:id="@+id/tvNoLayersHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/layer_note"
            android:textColor="#555"
            android:textSize="11sp"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <!-- ===================== KONTEKSTUAL: Video Controls (background/layer video) ===================== -->
        <LinearLayout
            android:id="@+id/layoutVideoControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="14dp"
            android:padding="10dp"
            android:background="@drawable/bg_scene_card"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VIDEO CONTROLS"
                android:textColor="#7FD8A6"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btnPlayVideo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_media_pause"
                    app:tint="#7FD8A6"
                    android:contentDescription="Play/pause video" />

                <SeekBar
                    android:id="@+id/seekVideoProgress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="1000" />

                <CheckBox
                    android:id="@+id/cbLoopVideo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loop"
                    android:textColor="#FFF"
                    android:textSize="12sp"
                    android:checked="true"
                    android:buttonTint="#7FD8A6" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===================== SIMPAN ===================== -->
        <Button
            android:id="@+id/btnSaveScene"
            style="@style/PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="💾 SIMPAN SCENE INI" />

    </LinearLayout>
</ScrollView>
