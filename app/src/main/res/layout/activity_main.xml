<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101114">

    <!-- ===================== TOP BAR (Mac Style) ===================== -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:background="#1B1D22"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/ic_delete"
            android:contentDescription="Close"
            app:tint="#444" />

        <TextView
            android:id="@+id/tvSceneNameTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Layar Utama"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnKanae"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="5dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/kanae"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:contentDescription="Kanae Music" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="5dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            android:tint="#FFFFFF"
            app:tint="#FFFFFF"
            android:contentDescription="Settings" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnVoiceAnim"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/camera_retro"
            android:tint="#FFFFFF"
            app:tint="#FFFFFF"
            android:contentDescription="Voice Animation" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnQuickLive"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/online_game"
            android:tint="#FFFFFF"
            app:tint="#FFFFFF"
            android:contentDescription="Live" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnSceneManager"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/new_product"
            android:tint="#FFFFFF"
            app:tint="#FFFFFF"
            android:contentDescription="Scene Manager" />

    </LinearLayout>

    <!-- ===================== PREVIEW LAYOUT ===================== -->
    <FrameLayout
        android:id="@+id/layoutPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@+id/bottomContainer"
        android:background="#000000"
        android:layout_margin="10dp">

        <ame.project.nlstudio.ui.SceneCanvasView
            android:id="@+id/sceneCanvasView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

        <ame.project.nlstudio.ui.QuickAnimationView
            android:id="@+id/quickAnimationView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:columnCount="3"
            android:rowCount="3">

            <!-- Row 1 -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnMoveUp"
                android:layout_row="0"
                android:layout_column="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:contentDescription="Move Up"
                android:src="@drawable/ic_chevron_right"
                android:rotation="-90"
                app:fabCustomSize="40dp"
                app:maxImageSize="24dp"
                app:backgroundTint="#2B2D32"
                app:tint="#7FD8A6"
                app:elevation="0dp" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabZoomIn"
                android:layout_row="0"
                android:layout_column="2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:contentDescription="Zoom In"
                android:src="@drawable/ic_zoom_in"
                app:fabCustomSize="40dp"
                app:maxImageSize="24dp"
                app:backgroundTint="#2B2D32"
                app:tint="#7FD8A6"
                app:elevation="0dp" />

            <!-- Row 2 -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnMoveLeft"
                android:layout_row="1"
                android:layout_column="0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:contentDescription="Move Left"
                android:src="@drawable/ic_chevron_right"
                android:rotation="180"
                app:fabCustomSize="40dp"
                app:maxImageSize="24dp"
                app:backgroundTint="#2B2D32"
                app:tint="#7FD8A6"
                app:elevation="0dp" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnMoveReset"
                android:layout_row="1"
                android:layout_column="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:contentDescription="Reset View"
                android:src="@drawable/ic_refresh"
                app:fabCustomSize="40dp"
                app:maxImageSize="24dp"
                app:backgroundTint="#2B2D32"
                app:tint="#7FD8A6"
                app:elevation="0dp" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnMoveRight"
                android:layout_row="1"
                android:layout_column="2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:contentDescription="Move Right"
                android:src="@drawable/ic_chevron_right"
                app:fabCustomSize="40dp"
                app:maxImageSize="24dp"
                app:backgroundTint="#2B2D32"
                app:tint="#7FD8A6"
                app:elevation="0dp" />

            <!-- Row 3 -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnMoveDown"
                android:layout_row="2"
                android:layout_column="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:contentDescription="Move Down"
                android:src="@drawable/ic_chevron_right"
                android:rotation="90"
                app:fabCustomSize="40dp"
                app:maxImageSize="24dp"
                app:backgroundTint="#2B2D32"
                app:tint="#7FD8A6"
                app:elevation="0dp" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabZoomOut"
                android:layout_row="2"
                android:layout_column="2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:contentDescription="Zoom Out"
                android:src="@drawable/ic_zoom_out"
                app:fabCustomSize="40dp"
                app:maxImageSize="24dp"
                app:backgroundTint="#2B2D32"
                app:tint="#7FD8A6"
                app:elevation="0dp" />
        </GridLayout>
        <TextView
            android:id="@+id/tvEmptyHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="SCENE KOSONG\nGeser menu di bawah untuk edit"
            android:textColor="#7FD8A6"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

    <!-- ===================== BOTTOM CONTAINER ===================== -->
    <LinearLayout
        android:id="@+id/bottomContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:background="#1B1D22"
        android:paddingTop="4dp"
        android:paddingBottom="16dp">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            app:tabIndicatorColor="#7FD8A6"
            app:tabIndicatorHeight="2dp"
            app:tabSelectedTextColor="#7FD8A6"
            app:tabTextColor="#555"
            app:tabTextAppearance="@style/TabTextStyle"
            app:tabRippleColor="@android:color/transparent"
            app:tabMode="fixed" />

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <Button
                android:id="@+id/btnStart"
                style="@style/PrimaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/live" />

            <Button
                android:id="@+id/btnTestRecord"
                style="@style/SecondaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/record" />

            <Button
                android:id="@+id/btnStop"
                style="@style/DangerButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/stop" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_gravity="center"
            android:text="Status: idle"
            android:textColor="#7FD8A6"
            android:textSize="11sp" />

    </LinearLayout>

</RelativeLayout>