<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101114">

    <!-- ===================== TOP BAR (Mac Style) ===================== -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:background="#1B1D22"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/ic_delete"
            android:contentDescription="Close"
            app:tint="#444" />

        <TextView
            android:id="@+id/tvSceneNameTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Layar Utama"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_preferences"
            app:tint="#FFFFFF"
            android:contentDescription="Settings" />

        <ImageButton
            android:id="@+id/btnQuickRecord"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="#FFFFFF"
            android:contentDescription="Record" />

        <ImageButton
            android:id="@+id/btnQuickLive"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/presence_video_online"
            app:tint="#FFFFFF"
            android:contentDescription="Live" />

        <ImageButton
            android:id="@+id/btnSceneManager"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_slideshow"
            app:tint="#FFFFFF"
            android:contentDescription="Scene Manager" />

    </LinearLayout>

    <!-- ===================== PREVIEW LAYOUT ===================== -->
    <FrameLayout
        android:id="@+id/layoutPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@+id/bottomContainer"
        android:background="#000000"
        android:layout_margin="10dp">

        <ame.project.nlstudio.ui.SceneCanvasView
            android:id="@+id/sceneCanvasView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/tvEmptyHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="SCENE KOSONG\nGeser menu di bawah untuk edit"
            android:textColor="#7FD8A6"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

    <!-- ===================== BOTTOM CONTAINER ===================== -->
    <LinearLayout
        android:id="@+id/bottomContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:background="#1B1D22"
        android:paddingTop="4dp"
        android:paddingBottom="16dp">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            app:tabIndicatorColor="#7FD8A6"
            app:tabIndicatorHeight="2dp"
            app:tabSelectedTextColor="#7FD8A6"
            app:tabTextColor="#555"
            app:tabTextAppearance="@style/TabTextStyle"
            app:tabRippleColor="@android:color/transparent"
            app:tabMode="fixed" />

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <Button
                android:id="@+id/btnStart"
                style="@style/PrimaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="🔴 LIVE" />

            <Button
                android:id="@+id/btnTestRecord"
                style="@style/SecondaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="🎬 TEST" />

            <Button
                android:id="@+id/btnStop"
                style="@style/DangerButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="⏹ STOP" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_gravity="center"
            android:text="Status: idle"
            android:textColor="#7FD8A6"
            android:textSize="11sp" />

    </LinearLayout>

</RelativeLayout>