<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <Spinner
        android:id="@+id/spinnerAudioSource"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/audio_source_options"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🎤 Mic" android:textColor="#FFF" android:textSize="12sp" />
        <TextView android:id="@+id/tvMicVolumeValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textColor="#7FD8A6" android:textSize="12sp" />
    </LinearLayout>
    <SeekBar android:id="@+id/seekMicVolume" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="200" android:progress="100" />
    <ame.project.nlstudio.ui.VuMeterView android:id="@+id/vuMicLevel" android:layout_width="match_parent" android:layout_height="8dp" android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🔊 Sistem" android:textColor="#FFF" android:textSize="12sp" />
        <TextView android:id="@+id/tvSystemVolumeValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textColor="#7FD8A6" android:textSize="12sp" />
    </LinearLayout>
    <SeekBar android:id="@+id/seekSystemVolume" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="200" android:progress="100" />
    <ame.project.nlstudio.ui.VuMeterView android:id="@+id/vuSystemLevel" android:layout_width="match_parent" android:layout_height="8dp" android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🎵 Music" android:textColor="#FFF" android:textSize="12sp" />
        <TextView android:id="@+id/tvMusicVolumeValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textColor="#7FD8A6" android:textSize="12sp" />
    </LinearLayout>
    <SeekBar android:id="@+id/seekMusicVolume" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="200" android:progress="100" />
    <ame.project.nlstudio.ui.VuMeterView android:id="@+id/vuMusicLevel" android:layout_width="match_parent" android:layout_height="8dp" />
</LinearLayout>