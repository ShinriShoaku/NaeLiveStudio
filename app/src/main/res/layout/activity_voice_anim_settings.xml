<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#101114">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1B1D22"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Voice Animation Settings"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSave"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="SIMPAN"
            android:textColor="#7FD8A6" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="KONFIGURASI TINGKAT SUARA"
                android:textColor="#7FD8A6"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tambahkan gambar untuk setiap tingkat volume suara (0-100)."
                android:textColor="#AAA"
                android:textSize="12sp"
                android:layout_marginBottom="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvVoiceAnimItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <Button
                android:id="@+id/btnAddItem"
                style="@style/SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="+ Tambah Tingkat Suara" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PENGATURAN EFEK (GLOW &amp; POP)"
                android:textColor="#7FD8A6"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvMinBrightnessLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kecerahan saat Hening: 50%"
                android:textColor="#FFF"
                android:textSize="12sp" />
            <SeekBar
                android:id="@+id/seekMinBrightness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:max="100" />

            <TextView
                android:id="@+id/tvScaleIntensityLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Intensitas Pop (Goncangan): 4%"
                android:textColor="#FFF"
                android:textSize="12sp" />
            <SeekBar
                android:id="@+id/seekScaleIntensity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:max="20" />

            <TextView
                android:id="@+id/tvEffectThresholdStartLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mulai Reaksi (Volume %): 0%"
                android:textColor="#FFF"
                android:textSize="12sp" />
            <SeekBar
                android:id="@+id/seekEffectThresholdStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:max="100" />

            <TextView
                android:id="@+id/tvEffectThresholdEndLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Maksimal Reaksi (Volume %): 50%"
                android:textColor="#FFF"
                android:textSize="12sp" />
            <SeekBar
                android:id="@+id/seekEffectThresholdEnd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:max="100" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TESTING"
                    android:textColor="#7FD8A6"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <Button
                    android:id="@+id/btnTestMic"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MULAI TEST MIC"
                    android:textColor="#7FD8A6"
                    android:textSize="11sp" />
            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="#000"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/ivPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_menu_gallery" />

                <ame.project.nlstudio.ui.VuMeterView
                    android:id="@+id/vuMeter"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_alignParentBottom="true" />
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>