<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1B1D22"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===================== PRESET LAYOUT ===================== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PILIH PRESET LAYOUT (CEPAT)"
            android:textColor="#7FD8A6"
            android:textStyle="bold"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">

                <!-- Preset: Portrait Game Tengah -->
                <LinearLayout
                    android:id="@+id/presetPortraitCenter"
                    android:layout_width="110dp"
                    android:layout_height="160dp"
                    android:orientation="vertical"
                    android:background="#2A2D34"
                    android:padding="8dp"
                    android:layout_marginEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <View android:layout_width="match_parent" android:layout_height="35dp" android:background="#444" />
                    <View android:layout_width="match_parent" android:layout_height="60dp" android:background="#7FD8A6" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"/>
                    <View android:layout_width="match_parent" android:layout_height="35dp" android:background="#444" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Game Tengah" android:textColor="#999" android:textSize="9sp" android:layout_marginTop="4dp" android:layout_gravity="center_horizontal"/>
                </LinearLayout>

                <!-- Preset: Portrait Game Atas -->
                <LinearLayout
                    android:id="@+id/presetPortraitTop"
                    android:layout_width="110dp"
                    android:layout_height="160dp"
                    android:orientation="vertical"
                    android:background="#2A2D34"
                    android:padding="8dp"
                    android:layout_marginEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <View android:layout_width="match_parent" android:layout_height="60dp" android:background="#7FD8A6" />
                    <View android:layout_width="match_parent" android:layout_height="70dp" android:background="#444" android:layout_marginTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Game Atas" android:textColor="#999" android:textSize="9sp" android:layout_marginTop="4dp" android:layout_gravity="center_horizontal"/>
                </LinearLayout>

                <!-- Preset: Portrait Game Bawah -->
                <LinearLayout
                    android:id="@+id/presetPortraitBottom"
                    android:layout_width="110dp"
                    android:layout_height="160dp"
                    android:orientation="vertical"
                    android:background="#2A2D34"
                    android:padding="8dp"
                    android:layout_marginEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <View android:layout_width="match_parent" android:layout_height="70dp" android:background="#444" />
                    <View android:layout_width="match_parent" android:layout_height="60dp" android:background="#7FD8A6" android:layout_marginTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Game Bawah" android:textColor="#999" android:textSize="9sp" android:layout_marginTop="4dp" android:layout_gravity="center_horizontal"/>
                </LinearLayout>

                <!-- Preset: Landscape Full -->
                <LinearLayout
                    android:id="@+id/presetLandscapeFull"
                    android:layout_width="180dp"
                    android:layout_height="110dp"
                    android:orientation="vertical"
                    android:background="#2A2D34"
                    android:padding="8dp"
                    android:layout_gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#7FD8A6" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Landscape Full" android:textColor="#999" android:textSize="9sp" android:layout_marginTop="2dp" android:layout_gravity="center_horizontal"/>
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>


        <!-- ===================== TOOLBAR LAYER ===================== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LAYER / OVERLAY"
            android:textColor="#7FD8A6"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnAddLayer"
                style="@style/SecondaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:text="+ Gambar / Icon" />

            <Button
                android:id="@+id/btnDeleteSelectedLayer"
                style="@style/SecondaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="11sp"
                android:enabled="false"
                android:alpha="0.4"
                android:text="🗑 Hapus Layer Ini" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333"
            android:layout_marginBottom="16dp" />

        <!-- ===================== SIMPAN SCENE ===================== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NAMA SCENE"
            android:textColor="#7FD8A6"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etNewSceneName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nama scene, misal: BRB, Iklan, Intro"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnNewScene"
                style="@style/SecondaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="🆕 Scene Baru" />

            <Button
                android:id="@+id/btnSaveScene"
                style="@style/PrimaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="12sp"
                android:text="💾 Simpan &amp; Terapkan" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333"
            android:layout_marginBottom="16dp" />

        <!-- ===================== SCENE TERSIMPAN ===================== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SCENE TERSIMPAN (tap = edit + langsung live)"
            android:textColor="#7FD8A6"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSceneList"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:clipToPadding="false" />

    </LinearLayout>
</ScrollView>