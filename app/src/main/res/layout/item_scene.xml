<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sceneCardRoot"
    android:layout_width="96dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="10dp"
    android:padding="4dp"
    android:background="@drawable/bg_scene_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/ivSceneThumb"
            android:layout_width="88dp"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:background="#000000"
            android:contentDescription="Thumbnail scene" />

        <TextView
            android:id="@+id/tvSceneName"
            android:layout_width="88dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Scene"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center" />

    </LinearLayout>

    <!-- Badge kecil "AKTIF" muncul di scene yang lagi dipakai buat live sekarang -->
    <TextView
        android:id="@+id/tvSceneActiveBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:background="#7FD8A6"
        android:paddingStart="5dp"
        android:paddingEnd="5dp"
        android:paddingTop="1dp"
        android:paddingBottom="1dp"
        android:text="LIVE"
        android:textColor="#101114"
        android:textSize="9sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/ivSceneDelete"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="top|end"
        android:background="#CC1B1D22"
        android:padding="2dp"
        android:src="@android:drawable/ic_menu_delete"
        app:tint="#FF6B6B"
        android:contentDescription="Hapus scene" />

</FrameLayout>