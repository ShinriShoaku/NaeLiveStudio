<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="LabelText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#9AA0A6</item>
        <item name="android:textSize">12sp</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">#E53950</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">14dp</item>
    </style>

    <style name="SecondaryButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">#2C2F36</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:padding">14dp</item>
    </style>

    <style name="DangerButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">#3A3D44</item>
        <item name="android:textColor">#FF8A8A</item>
        <item name="android:padding">14dp</item>
    </style>

    <style name="SceneButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">#2C2F36</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="ShapeAppearance.Circle" parent="">
        <item name="cornerSize">50%</item>
    </style>
</resources>